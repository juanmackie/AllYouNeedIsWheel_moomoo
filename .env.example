# Moomoo OpenD Credentials
MOOMOO_LOGIN=your-email@example.com
MOOMOO_PASSWORD=your-moomoo-password

# Trading Password (required for live trading)
MOOMOO_TRADING_PASSWORD=your-trading-password

# Optional: Language (en or ch)
MOOMOO_LANG=en

# Optional: OpenD log level (no, debug, info)
MOOMOO_LOG_LEVEL=info

# Optional: Port overrides
# OPEND_PORT=11111
# APP_PORT=8000
